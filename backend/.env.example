NODE_ENV=development
PORT=8000
MONGO_URI=mongodb://127.0.0.1:27017/lms_db
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=1d
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# Optional cloud storage
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=institute-lms

# Speaking module integrations
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
ELEVENLABS_MODEL_ID=eleven_multilingual_v2
OPENAI_API_KEY=
OPENAI_SPEECH_TO_TEXT_MODEL=gpt-4o-mini-transcribe
OPENAI_EVALUATION_MODEL=gpt-4.1-mini

# Bootstrap defaults (used when app starts)
DEFAULT_SUPER_ADMIN_EMAIL=admin@gmail.com
DEFAULT_SUPER_ADMIN_PASSWORD=Admin123
DEFAULT_SUPER_ADMIN_FIRST_NAME=Super
DEFAULT_SUPER_ADMIN_LAST_NAME=Admin
DEFAULT_SUPER_ADMIN_MOB_NO=9999999999
