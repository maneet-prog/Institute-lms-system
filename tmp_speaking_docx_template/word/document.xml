  <w:body>
    <w:p><w:r><w:t>TECAI Speaking Test Template</w:t></w:r></w:p>
    <w:p><w:r><w:t>[TECAI SPEAKING START]</w:t></w:r></w:p>
    <w:p><w:r><w:t>[INSTRUCTION]</w:t></w:r></w:p>
    <w:p><w:r><w:t>Welcome to the speaking examination.</w:t></w:r></w:p>
    <w:p><w:r><w:t>You will hear each prompt, prepare for the given time, and then record your answer.</w:t></w:r></w:p>
    <w:p><w:r><w:t>[PART 1: Introduction &amp; Interview]</w:t></w:r></w:p>
    <w:p><w:r><w:t>[QUESTION]</w:t></w:r></w:p>
    <w:p><w:r><w:t>Could you introduce yourself and describe your hometown?</w:t></w:r></w:p>
    <w:p><w:r><w:t>[PREP: 5]</w:t></w:r></w:p>
    <w:p><w:r><w:t>[RECORD: 30]</w:t></w:r></w:p>
    <w:p><w:r><w:t>[QUESTION]</w:t></w:r></w:p>
    <w:p><w:r><w:t>What do you like most about your neighborhood, and why?</w:t></w:r></w:p>
    <w:p><w:r><w:t>[PREP: 5]</w:t></w:r></w:p>
    <w:p><w:r><w:t>[RECORD: 30]</w:t></w:r></w:p>
    <w:p><w:r><w:t>[PART 2: Cue Card Long Turn]</w:t></w:r></w:p>
    <w:p><w:r><w:t>[INSTRUCTION]</w:t></w:r></w:p>
    <w:p><w:r><w:t>You should speak for one to two minutes on the following topic.</w:t></w:r></w:p>
    <w:p><w:r><w:t>[QUESTION]</w:t></w:r></w:p>
    <w:p><w:r><w:t>Describe a beautiful place you visited in your childhood.</w:t></w:r></w:p>
    <w:p><w:r><w:t>You should say:</w:t></w:r></w:p>
    <w:p><w:r><w:t>where it was</w:t></w:r></w:p>
    <w:p><w:r><w:t>when you went there</w:t></w:r></w:p>
    <w:p><w:r><w:t>what you did there</w:t></w:r></w:p>
    <w:p><w:r><w:t>and explain why you still remember it.</w:t></w:r></w:p>
    <w:p><w:r><w:t>[PREP: 60]</w:t></w:r></w:p>
    <w:p><w:r><w:t>[RECORD: 120]</w:t></w:r></w:p>
    <w:p><w:r><w:t>[PART 3: Discussion]</w:t></w:r></w:p>
    <w:p><w:r><w:t>[QUESTION]</w:t></w:r></w:p>
    <w:p><w:r><w:t>Why do you think some childhood memories remain vivid for many years?</w:t></w:r></w:p>
    <w:p><w:r><w:t>[PREP: 10]</w:t></w:r></w:p>
    <w:p><w:r><w:t>[RECORD: 45]</w:t></w:r></w:p>
    <w:p><w:r><w:t>[QUESTION]</w:t></w:r></w:p>
    <w:p><w:r><w:t>How can travel experiences help children learn about the world?</w:t></w:r></w:p>
    <w:p><w:r><w:t>[PREP: 10]</w:t></w:r></w:p>
    <w:p><w:r><w:t>[RECORD: 45]</w:t></w:r></w:p>
    <w:p><w:r><w:t>[TECAI SPEAKING END]</w:t></w:r></w:p>
